# Variáveis injetadas automaticamente pelo Lovable Cloud — não editar à mão.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Configuração do trigger on_print_job_created (process-print-job).
# Estas variáveis NÃO são lidas pelo runtime — servem como referência para
# popular as settings do banco que o trigger usa em current_setting():
#
#   ALTER DATABASE postgres SET app.edge_function_url = 'https://<project-ref>.supabase.co/functions/v1';
#   ALTER DATABASE postgres SET app.service_role_key  = '<SUPABASE_SERVICE_ROLE_KEY>';
#
# Sem isso o trigger fica inativo (o frontend continua disparando a function
# como fallback via supabase.functions.invoke).
# ---------------------------------------------------------------------------
SUPABASE_EDGE_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1
